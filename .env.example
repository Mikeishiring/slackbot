# Runtime mode: slack (full bot), local (CLI/scripting), worker (job processor)
POLICY_BOT_RUNTIME=slack
POLICY_BOT_POLICY_DIR=./policy
POLICY_BOT_DATA_DIR=./var
POLICY_BOT_DB_PATH=./var/policy-bot.sqlite
POLICY_BOT_ARTIFACT_DIR=./var/artifacts
POLICY_BOT_REPORT_DIR=./var/reports
POLICY_BOT_EXPORT_DIR=./var/exports
POLICY_BOT_BROWSER_HEADLESS=true
POLICY_BOT_WORKER_POLL_MS=5000
POLICY_BOT_RETENTION_DAYS=365
POLICY_BOT_ENTITY_EVIDENCE_CACHE_DIR=./var/entity-evidence-cache
POLICY_BOT_ENTITY_EVIDENCE_CACHE_HOURS=24
POLICY_BOT_ENTITY_EVIDENCE_BROWSER_ATTEMPTS=3
POLICY_BOT_ENTITY_EVIDENCE_BROWSER_WAIT_MS=4000
POLICY_BOT_ENTITY_EVIDENCE_LOAD_TIMEOUT_MS=20000
POLICY_BOT_BATCH_WORKERS=3
POLICY_BOT_JOB_MAX_ATTEMPTS=3
POLICY_BOT_JOB_RETRY_DELAY_MS=5000
POLICY_BOT_JOB_LOCK_TIMEOUT_MS=600000

# Google Drive — auto-uploads reports to a shared folder
# Create a service account, download JSON key, share a Drive folder with its email
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=./google-service-account.json
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Web search API for reputation checks (recommended — avoids bot detection)
# Brave Search (preferred): 2,000 free queries/month — https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
# Google Custom Search (alternative): 100 free queries/day
# GOOGLE_SEARCH_API_KEY=AIza...
# GOOGLE_SEARCH_ENGINE_ID=a1b2c3...

# OFAC dataset URLs (override if Treasury changes endpoints)
# POLICY_BOT_OFAC_DATASET_URLS=https://www.treasury.gov/ofac/downloads/sdn.xml,https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/ADVANCED_XML

# Access control - comma-separated Slack user IDs allowed to finalize/resolve (empty = anyone)
# POLICY_BOT_REVIEWER_USER_IDS=U12345,U67890

# Slack - required when POLICY_BOT_RUNTIME=slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Anthropic - required for natural language interaction
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-opus-4-20250514
ANTHROPIC_REQUEST_TIMEOUT_MS=30000
ANTHROPIC_MAX_RETRIES=2
